          "exerciseModules": ["stage2/missing-data"],
          "estimatedMinutes": 25
        },
        {
          "id": "boolean-indexing",
          "order": 3,
          "title": { "zh": "布尔索引过滤", "en": "Boolean Indexing" },
          "description": {
            "zh": "使用布尔条件过滤数据",
