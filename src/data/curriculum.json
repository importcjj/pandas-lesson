          "exerciseModules": ["stage2/boolean-indexing"],
          "estimatedMinutes": 25
        },
        {
          "id": "columns-ops",
          "order": 4,
          "title": { "zh": "增删列", "en": "Column Operations" },
          "description": {
            "zh": "添加、删除和修改列",
