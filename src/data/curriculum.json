{
  "stages": [
    {
      "id": "stage1",
      "title": { "zh": "基础入门", "en": "Foundations" },
      "description": {
        "zh": "学习 pandas 的核心数据结构和基本操作",
        "en": "Learn core data structures and basic operations in pandas"
      },
      "requiredCompletionRate": 0.8,
      "lessons": [
        {
          "id": "intro",
          "order": 1,
          "title": { "zh": "pandas 简介与导入", "en": "Introduction to pandas" },
          "description": {
            "zh": "了解 pandas 是什么，如何安装和导入",
            "en": "Understand what pandas is, how to install and import it"
          },
          "exerciseModules": ["stage1/intro"],
          "estimatedMinutes": 15
        },
        {
          "id": "series-basics",
          "order": 2,
          "title": { "zh": "Series 基础", "en": "Series Basics" },
          "description": {
            "zh": "创建 Series、索引和基本操作",
            "en": "Create Series, indexing, and basic operations"
          },
          "exerciseModules": ["stage1/series-basics"],
          "estimatedMinutes": 25
        },
        {
          "id": "dataframe-creation",
          "order": 3,
          "title": { "zh": "DataFrame 创建", "en": "Creating DataFrames" },
          "description": {
            "zh": "从字典、列表、CSV 等创建 DataFrame",
            "en": "Create DataFrames from dicts, lists, CSV, etc."
          },
          "exerciseModules": ["stage1/dataframe-creation"],
          "estimatedMinutes": 25
        },
        {
          "id": "data-inspection",
          "order": 4,
          "title": { "zh": "数据检查", "en": "Data Inspection" },
          "description": {
            "zh": "使用 head、tail、info、describe、shape 查看数据",
            "en": "Inspect data with head, tail, info, describe, shape"
          },
          "exerciseModules": ["stage1/data-inspection"],
          "estimatedMinutes": 20
        },
        {
          "id": "selection",
          "order": 5,
          "title": { "zh": "列选择与行切片", "en": "Column Selection & Row Slicing" },
          "description": {
            "zh": "选择列、切片行、基础数据提取",
            "en": "Select columns, slice rows, basic data extraction"
          },
          "exerciseModules": ["stage1/selection"],
          "estimatedMinutes": 25
        },
        {
          "id": "loc-iloc",
          "order": 6,
          "title": { "zh": "loc 和 iloc 索引", "en": "loc and iloc Indexing" },
          "description": {
            "zh": "使用 loc 和 iloc 进行标签和位置索引",
            "en": "Label-based and position-based indexing with loc and iloc"
          },
          "exerciseModules": ["stage1/loc-iloc"],
          "estimatedMinutes": 30
        },
        {
          "id": "dtypes",
          "order": 7,
          "title": { "zh": "数据类型与 dtypes", "en": "Data Types & dtypes" },
          "description": {
            "zh": "理解和检查数据类型",
            "en": "Understand and inspect data types"
          },
          "exerciseModules": ["stage1/dtypes"],
          "estimatedMinutes": 20
        },
        {
          "id": "sorting",
          "order": 8,
          "title": { "zh": "排序", "en": "Sorting" },
          "description": {
            "zh": "使用 sort_values 和 sort_index 排序数据",
            "en": "Sort data with sort_values and sort_index"
          },
          "exerciseModules": ["stage1/sorting"],
          "estimatedMinutes": 20
        },
        {
          "id": "numpy-basics",
          "order": 9,
          "title": { "zh": "NumPy 基础", "en": "NumPy Basics" },
          "description": {
            "zh": "学习 NumPy 数组操作，为 pandas 的向量化计算打基础",
            "en": "Learn NumPy array operations as foundation for pandas vectorized computing"
          },
          "exerciseModules": ["stage1/numpy-basics"],
          "estimatedMinutes": 25
        },
        {
          "id": "numpy-broadcasting",
          "order": 10,
          "title": { "zh": "NumPy 广播机制", "en": "NumPy Broadcasting" },
          "description": {
            "zh": "深入理解广播规则，掌握不同形状数组的运算技巧",
            "en": "Deep dive into broadcasting rules and operations with different shaped arrays"
          },
          "exerciseModules": ["stage1/numpy-broadcasting"],
          "estimatedMinutes": 30
        }
      ]
    },
    {
      "id": "stage2",
      "title": { "zh": "数据清洗", "en": "Data Wrangling" },
      "description": {
        "zh": "掌握数据清洗和转换的核心技能",
        "en": "Master core skills for data cleaning and transformation"
      },
      "requiredCompletionRate": 0.8,
      "lessons": [
        {
          "id": "file-io",
          "order": 1,
          "title": { "zh": "读写文件", "en": "Reading & Writing Files" },
          "description": {
            "zh": "读写 CSV、JSON、Excel 文件",
            "en": "Read and write CSV, JSON, Excel files"
          },
          "exerciseModules": ["stage2/file-io"],
          "estimatedMinutes": 25
        },
        {
          "id": "missing-data",
          "order": 2,
          "title": { "zh": "缺失值处理", "en": "Handling Missing Data" },
          "description": {
            "zh": "检测、填充和删除缺失值",
